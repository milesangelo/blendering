# SiliconFlow API key (used by LiteLLM when provider="siliconflow" or model="openai/..."
# with api_base pointed at SiliconFlow). Pick whichever your config.yaml expects.
SILICONFLOW_API_KEY=sk-...

# If you point LiteLLM at SiliconFlow through the OpenAI-compatible interface, set this too:
OPENAI_API_KEY=${SILICONFLOW_API_KEY}

# Optional: override default config path
# BLENDERING_CONFIG=./config.yaml
